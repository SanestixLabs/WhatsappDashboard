# ============================================================
# Sanestix Flow — Backend Environment Variables
# Copy to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sanestix_flow
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_token_secret_different_from_above
JWT_REFRESH_EXPIRES_IN=7d

# Meta / WhatsApp Cloud API
META_VERIFY_TOKEN=your_meta_webhook_verify_token
META_APP_SECRET=your_meta_app_secret
WHATSAPP_ACCESS_TOKEN=your_permanent_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_VERSION=v19.0

# n8n
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/sanestix
N8N_SECRET=your_n8n_webhook_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
