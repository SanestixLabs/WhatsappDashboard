# ============================================================
# Sanestix Flow — Root Docker Compose Environment
# Copy to .env and fill in all values
# ============================================================

# Domain
FRONTEND_URL=https://YOUR_DOMAIN.com
FRONTEND_API_URL=https://YOUR_DOMAIN.com
FRONTEND_SOCKET_URL=https://YOUR_DOMAIN.com

# Database
DB_NAME=sanestix_flow
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# JWT
JWT_SECRET=CHANGE_THIS_MIN_32_CHAR_SECRET_KEY
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_THIS_DIFFERENT_32_CHAR_KEY
JWT_REFRESH_EXPIRES_IN=7d

# Meta / WhatsApp
META_VERIFY_TOKEN=CHANGE_THIS_CUSTOM_VERIFY_TOKEN
META_APP_SECRET=your_meta_app_secret_from_developers_portal
WHATSAPP_ACCESS_TOKEN=your_permanent_whatsapp_system_user_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_VERSION=v19.0

# n8n
N8N_WEBHOOK_URL=https://your-n8n.domain.com/webhook/sanestix
N8N_SECRET=CHANGE_THIS_N8N_SECRET
